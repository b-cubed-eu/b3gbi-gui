linters: linters_with_defaults(
    line_length_linter(120),
    object_length_linter(50),
    object_name_linter("snake_case"),
    commented_code_linter = NULL,
    trailing_blank_lines_linter = NULL
  )
exclusions: list(
    "R/RcppExports.R",
    "renv",
    "data",
    "www",
    "modules"
  )
encoding: "UTF-8"
